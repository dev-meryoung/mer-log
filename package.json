{
  "name": "mer-log",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.7.0",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "npm run generate:posts && next dev --turbopack",
    "build": "npm run generate:posts && next build",
    "start": "next start",
    "generate:posts": "tsx ./scripts/generate-post-cache.ts",
    "check:images": "tsx ./scripts/check-post-images.ts",
    "check:images:strict": "tsx ./scripts/check-post-images.ts --strict",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "typecheck": "tsc --noEmit --incremental false",
    "verify": "npm run lint:check && npm run typecheck && npm run check:images && npm run build"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@types/unist": "^3.0.3",
    "date-fns": "^4.1.0",
    "image-size": "^2.0.2",
    "js-yaml": "^4.2.0",
    "next": "^16.2.9",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "plaiceholder": "^3.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-pretty-code": "^0.14.0",
    "remark": "^15.0.1",
    "strip-markdown": "^6.0.0",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/eslintrc": "^3.3.3",
    "@tailwindcss/typography": "^0.5.20",
    "@types/hast": "^3.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.19",
    "eslint-plugin-prettier": "^5.5.5",
    "lefthook": "^2.0.15",
    "p-limit": "^7.2.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
